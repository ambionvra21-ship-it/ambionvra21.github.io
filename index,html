/* ---------- Expense Tracker ---------- */
let expenseChartInstance = null;
function getExpenseData(){
  return JSON.parse(localStorage.getItem('vt_expenses') || "[]");
}
function addExpense(){
  const amount = parseFloat(document.getElementById('expAmount').value);
  const currency = document.getElementById('expCurrency').value;
  const category = document.getElementById('expCategory').value;
  const note = document.getElementById('expNote').value;
  if(!amount || amount <= 0){ alert("Enter a valid amount."); return; }
  const data = getExpenseData();
  data.push({ date: new Date().toISOString().slice(0,10), amount, currency, category, note });
  localStorage.setItem('vt_expenses', JSON.stringify(data));
  document.getElementById('expAmount').value = '';
  document.getElementById('expNote').value = '';
  renderExpenses();
}
function deleteExpense(i){
  const data = getExpenseData();
  data.splice(i,1);
  localStorage.setItem('vt_expenses', JSON.stringify(data));
  renderExpenses();
}
function renderExpenses(){
  const data = getExpenseData();
  const thisMonth = new Date().toISOString().slice(0,7);
  const monthEntries = data.filter(e => e.date.startsWith(thisMonth));
  const totalsByCurrency = {};
  monthEntries.forEach(e => {
    const cur = e.currency || '₱';
    totalsByCurrency[cur] = (totalsByCurrency[cur] || 0) + e.amount;
  });
  const totalText = Object.entries(totalsByCurrency).map(([cur, amt]) => `${cur}${amt.toLocaleString()}`).join(' + ') || '0';
  document.getElementById('expTotal').innerText = totalText;

  const listEl = document.getElementById('expenseList');
  listEl.innerHTML = data.slice().reverse().map((e, ri) => {
    const i = data.length - 1 - ri;
    const cur = e.currency || '₱';
    return `<div class="entry-row"><span>${e.date} — ${e.category}${e.note ? ' ('+e.note+')' : ''}: ${cur}${e.amount.toLocaleString()}</span><button class="del" onclick="deleteExpense(${i})">×</button></div>`;
  }).join('') || `<p class="muted">No expenses logged yet.</p>`;

  const byCategory = {};
  data.forEach(e => { byCategory[e.category] = (byCategory[e.category]||0) + e.amount; });
  const ctx = document.getElementById('expenseChart');
  if(expenseChartInstance) expenseChartInstance.destroy();
  if(typeof Chart === 'undefined' || data.length === 0) return;
  expenseChartInstance = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: Object.keys(byCategory),
      datasets: [{ label: 'Spent by category (₱)', data: Object.values(byCategory), backgroundColor:'#14b8a6' }]
    },
    options: { responsive:true, plugins:{ legend:{ display:false } }, scales:{ y:{ beginAtZero:true } } }
  });
}
renderExpenses();

/* ---------- Share ---------- */
function shareTo(platform){
  const url = encodeURIComponent(window.location.href);
  const text = encodeURIComponent("Check out this free health & daily tools tracker!");
  let shareUrl = "";
  if(platform === 'facebook') shareUrl = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
  if(platform === 'twitter') shareUrl = `https://twitter.com/intent/tweet?url=${url}&text=${text}`;
  if(platform === 'whatsapp') shareUrl = `https://wa.me/?text=${text}%20${url}`;
  if(platform === 'email') shareUrl = `mailto:?subject=${text}&body=${url}`;
  window.open(shareUrl, '_blank');
}
function copyLink(){
  navigator.clipboard.writeText(window.location.href).then(() => alert("Link copied!"));
